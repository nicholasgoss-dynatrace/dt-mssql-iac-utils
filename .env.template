# Per-tenant Dynatrace API tokens.
# Each _tenant.yaml references the env var name to use for that tenant.
# Add one entry per tenant — name them however makes sense for your org.
#
# Required scopes per token:
#   - extensions.write       (deploy_configs.py)
#   - extensions.read        (deploy_configs.py --list)
#   - credentialVault.read   (deploy_configs.py)
#   - credentialVault.write  (create_credential.py)

DT_API_TOKEN_PROD=
DT_API_TOKEN_NONPROD=

# SQL Server credentials (used only by create_credential.py).
# Run create_credential.py once per service account to register it in the
# Credential Vault, then paste the returned ID into your endpoint YAML files.
# Do NOT commit a populated .env file to source control.
MSSQL_CRED_USERNAME=
MSSQL_CRED_PASSWORD=
